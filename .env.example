# ==============================
# GREENFIELD UNIVERSITY CHATBOT
# Environment Variables
# ==============================

# ---- LLM API Keys (provide at least one) ----
ANTHROPIC_API_KEY=your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here
GROQ_API_KEY=your-groq-key-here
DATABASE_URL=postgresql://postgres:97449061@localhost:5432/university_chatbot

# ---- Database ----
# PostgreSQL (recommended)
DATABASE_URL=postgresql://postgres:97449061@localhost:5432/university_chatbot

# MySQL alternative:
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/university_chatbot

# ---- App Settings ----
APP_ENV=development         # development | production
APP_PORT=8000
APP_HOST=0.0.0.0

# ---- RAG Settings ----
# Similarity threshold (0.0 - 1.0): higher = stricter matching
RAG_SIMILARITY_THRESHOLD=0.25
# Number of chunks to retrieve per query
RAG_TOP_K=5
# Chunk size in characters
RAG_CHUNK_SIZE=500
# Chunk overlap in characters
RAG_CHUNK_OVERLAP=100

# ---- Embedding Settings ----
# Use local sentence-transformers (free) or openai (requires API key)
# Options: local | openai
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
